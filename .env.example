# ──────────────────────────────────────────────────────────────────
# Project White — Environment Variables
# Copy to .env or export directly. All are optional.
# ──────────────────────────────────────────────────────────────────

# ── Client (pw) ──────────────────────────────────────────────────

## Signaling server URL (default: https://pw.example.com)
## Used by: send, receive, update
# PW_SERVER=https://pw-server.onrender.com

## File chunk size in bytes (default: 65536)
# PW_CHUNK_SIZE=131072

## Idle timeout in seconds (default: 120 for send, 30 for receive)
# PW_TIMEOUT=300

## Output directory for received files (default: .)
# PW_OUTPUT=~/Downloads

## Public IP for NAT traversal (send only, optional)
# PW_PUBLIC_IP=203.0.113.42

# ── Server (pw-server) ───────────────────────────────────────────

## Listen address (default: 0.0.0.0:8080)
# PW_SERVER_ADDR=127.0.0.1:8080

## Log level (default: info). See tracing-subscriber docs.
# RUST_LOG=debug
